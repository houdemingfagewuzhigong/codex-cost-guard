{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "codex-cost-guard",
          "rules": []
        }
      },
      "results": [
        {
          "ruleId": "codex-cost-guard.token-budget-exceeded",
          "level": "warning",
          "message": {
            "text": "sample-session.log: token budget exceeded (90 estimated tokens)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "sample-session.log"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
